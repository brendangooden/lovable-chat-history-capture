# ---- Required ----

# Firebase Web API key. Extracted from the key name in browser IndexedDB:
#   firebase:authUser:{apiKey}:[DEFAULT]
# Matches /AIzaSy[0-9A-Za-z_-]{33}/.
LOVABLE_FIREBASE_API_KEY=

# Firebase refresh token. Extract from browser IndexedDB entry
#   firebase:authUser:{apiKey}:[DEFAULT]
# under stsTokenManager.refreshToken.
# Treat this like a password — it grants full read access to your Lovable account.
LOVABLE_REFRESH_TOKEN=

# Lovable project UUID — from lovable.dev/projects/<uuid>.
LOVABLE_PROJECT_ID=

# Firestore GCP project hosting Lovable data.
# Discover yours in DevTools → Network: any firestore.googleapis.com URL contains
# /projects/<id>/databases/ — paste that <id> here (e.g. gpt-engineer-xxxxxx).
LOVABLE_FIRESTORE_PROJECT=

# Lovable API base URL used to mint signed download URLs for attachments.
# Defaults to https://api.lovable.dev.
LOVABLE_API_BASE=https://api.lovable.dev

# ---- Optional ----

# Where to write chat-history/ output. Defaults to ./chat-history
# OUTPUT_DIR=./chat-history